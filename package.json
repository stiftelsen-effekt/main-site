{
  "name": "main-site",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "echo 'Building Sanity to public/studio' && npm i --prefix studio && dotenv -e .env.sanity.build -- npm run build --prefix studio -- ../public/studio -y && echo 'Done'",
    "build": "next build",
    "sanity": "dotenv -e .env.local npm run start -- --prefix studio",
    "sanity:edit": "dotenv -e .env.local npm run edit -- --prefix studio",
    "sanity:list:pages": "dotenv -e .env.local npm run list:pages -- --prefix studio",
    "deploy-dk-dataset": "node scripts/deploy-dk-dataset.js",
    "start": "next start",
    "lint": "eslint .",
    "cypress:no": "cross-env CYPRESS_PATH=node_modules/.bin/cypress cypress open --config-file cypress-no.config.ts",
    "cypress:se": "cross-env CYPRESS_PATH=node_modules/.bin/cypress cypress open --config-file cypress-se.config.ts",
    "cypress:dk": "cross-env CYPRESS_PATH=node_modules/.bin/cypress cypress open --config-file cypress-dk.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "format": "prettier --write \"./**/*{js,ts,jsx,tsx,json,md,css,scss,yml}\"",
    "prepare": "husky install",
    "analyze": "next experimental-analyze",
    "generate:wealthmountain": "npx tsx components/main/blocks/WealthCalculator/data/processInput.ts"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.19.0",
    "@observablehq/plot": "^0.6.17",
    "@portabletext/react": "^6.2.0",
    "@redux-devtools/extension": "^4.0.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-kit": "^6.2.0",
    "@sanity/preview-url-secret": "^4.0.7",
    "@sanity/react-loader": "^2.0.13",
    "@sanity/visual-editing": "^5.4.4",
    "@ssfbank/norwegian-id-validators": "^1.0.0",
    "@stdlib/stats-base-dists-truncated-normal": "^0.2.3",
    "@vercel/kv": "^3.0.0",
    "babel-jest": "^30.4.1",
    "cookies-next": "^6.1.1",
    "d3": "^7.9.0",
    "html-react-parser": "^6.1.3",
    "jwt-decode": "^4.0.0",
    "katex": "^0.17.0",
    "luxon": "^3.7.2",
    "next": "^16.2.9",
    "next-plausible": "^3.12.5",
    "next-sanity": "^13.1.1",
    "next-seo": "^7.2.0",
    "organisationsnummer": "^1.2.0",
    "personnummer": "^3.2.1",
    "react": "^19.2.7",
    "react-animate-height": "^3.2.4",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.7.0",
    "react-feather": "^2.0.10",
    "react-hook-form": "^7.79.0",
    "react-hook-inview": "^4.5.1",
    "react-number-format": "^5.4.5",
    "react-redux": "^9.3.0",
    "react-toastify": "^11.1.0",
    "react-youtube": "^10.1.0",
    "redux-saga": "^1.5.0",
    "sanity-image": "^1.1.0",
    "sass": "^1.101.0",
    "styled-components": "^6.4.2",
    "swr": "^2.4.1",
    "textures": "^1.2.3",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/d3": "^7.4.3",
    "@types/d3-path": "^3.1.1",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/styled-components": "^5.1.36",
    "babel-loader": "^10.1.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^7.0.0",
    "cypress": "^15.17.0",
    "cypress-dotenv": "^3.0.1",
    "cypress-localstorage-commands": "^2.3.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "2.8.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-fsa": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md,css,scss,yml}": "prettier --write"
  },
  "overrides": {
    "@types/react": "^19.2.17"
  }
}
